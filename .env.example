# Copy this file to .env and fill in your Supabase project's values.
# Find these in your Supabase project: Settings -> API.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: overrides the fallback order-notification email used by the
# Shop checkout form (src/pages/Shop.jsx).
VITE_ORDER_EMAIL=dinisha@lanmic.com
